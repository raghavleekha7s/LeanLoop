# ─── Public host ──────────────────────────────────────────────────────────────
# Set DOMAIN to your real domain in production — Caddy uses it to provision
# a Let's Encrypt cert automatically. Keep "localhost" for local dev.
DOMAIN=localhost
PROTOCOL=http
ACME_EMAIL=admin@example.com

# ─── n8n ──────────────────────────────────────────────────────────────────────
N8N_HOST=n8n
N8N_PORT=5678
N8N_BASE_URL=http://n8n:5678
N8N_ENCRYPTION_KEY=change-me-to-a-long-random-string
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# n8n → Postgres (also used by the dashboard for its own tables)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=change-me

# n8n REST API key (generate from n8n UI → Settings → API)
N8N_API_KEY=

# ─── Dashboard ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=LeanLoop
N8N_INTERNAL_URL=http://n8n:5678
LEANLOOP_ADMIN_PASSWORD=

# ─── WhatsApp Business API (operator alerts + inbound webhooks) ───────────────
# Permanent access token from Meta → System Users.
WHATSAPP_API_TOKEN=
# Phone Number ID from Meta → WhatsApp → API Setup.
WHATSAPP_PHONE_NUMBER_ID=
# Where outbound failure alerts go (E.164, e.g. +919876543210).
WHATSAPP_ALERT_RECIPIENT=
# Random token Meta echoes back during webhook subscription. Generated by
# install.sh on first run; paste the same value into Meta → Webhooks → Verify token.
WHATSAPP_VERIFY_TOKEN=
# Path of the webhook node inside the activated WhatsApp template workflow.
# Must match the `path` field in the template JSON.
WHATSAPP_N8N_PATH=whatsapp-order

# ─── Google OAuth (for Sheets / Gmail templates) ──────────────────────────────
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# and add https://<DOMAIN>/api/oauth/google/callback as the authorized redirect.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
