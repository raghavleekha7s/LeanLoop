# LeanLoop reverse proxy.
# - Caddy auto-issues a Let's Encrypt cert for {$DOMAIN} on first request.
# - For DOMAIN=localhost, Caddy serves plain HTTP (no cert provisioning).
# - Routes /n8n/* to the n8n container, everything else to the dashboard.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	# n8n UI + API. Strip the /n8n prefix before forwarding so n8n sees
	# request paths starting at /.
	handle_path /n8n/* {
		reverse_proxy n8n:5678
	}

	# Dashboard (everything else).
	reverse_proxy dashboard:3000
}
